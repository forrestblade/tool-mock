{
  "name": "tool-mock",
  "version": "0.1.1",
  "type": "module",
  "description": "Mock framework for Claude Code tool responses — test hooks and Sentinel state transitions without real side effects",
  "bin": {
    "tool-mock": "bin/tool-mock.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "validate": "tsc --noEmit && eslint .",
    "prepublishOnly": "npm run validate && npm run build"
  },
  "author": "Forrest",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@valencets/resultkit": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "neostandard": "^0.12.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  }
}
